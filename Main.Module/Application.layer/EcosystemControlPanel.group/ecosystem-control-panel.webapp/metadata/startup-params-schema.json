{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "port": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "serverName": {
      "type": "string"
    },
    "serverManagerUrl": {
      "type": "string",
      "format": "uri"
    },
    "packagePath": {
      "type": "string"
    },
    "installDataDirPath": {
      "type": "string"
    },
    "panelStateFilePath": {
      "type": "string"
    },
    "ecosystemDefaultsFileRelativePath": {
      "type": "string"
    }
  },
  "required": [
    "port",
    "serverName",
    "serverManagerUrl",
    "packagePath",
    "installDataDirPath",
    "ecosystemDefaultsFileRelativePath"
  ]
}
