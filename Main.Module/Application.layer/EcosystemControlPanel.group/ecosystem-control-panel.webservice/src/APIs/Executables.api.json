{
	"name": "Executables",
	"endpoints": [
		{
			"summary": "ListExecutables",
			"method": "GET",
			"path": "/executables"
		},
		{
			"summary": "GetExecutableInformation",
			"method": "POST",
			"path": "/executable-information",
			"parameters": [
				{
					"name": "executableName",
					"in": "body",
					"type": "string",
					"required": true
				}
			]
		},
		{
			"summary": "GetExecutableIcon",
			"method": "GET",
			"path": "/executable-icon/:executableName",
			"typeResponse": "file",
			"parameters": [
				{
					"name": "executableName",
					"in": "path",
					"type": "string",
					"required": true
				}
			]
		},
		{
			"summary": "InstallExecutable",
			"method": "POST",
			"path": "/install-executable",
			"parameters": [
				{
					"name": "executableName",
					"in": "body",
					"type": "string",
					"required": true
				}
			]
		}
	]
}
