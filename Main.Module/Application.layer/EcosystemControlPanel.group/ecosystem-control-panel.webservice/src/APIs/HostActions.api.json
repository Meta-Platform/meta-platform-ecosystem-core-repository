{
	"name": "HostActions",
	"endpoints": [
		{
			"summary": "RunPackage",
			"method": "POST",
			"path": "/run-package",
			"parameters": [
				{ "name": "packagePath", "in": "body", "type": "string", "required": true }
			]
		},
		{
			"summary": "OpenVSCode",
			"method": "POST",
			"path": "/open-vscode",
			"parameters": [
				{ "name": "targetPath", "in": "body", "type": "string", "required": true }
			]
		},
		{
			"summary": "OpenTerminal",
			"method": "POST",
			"path": "/open-terminal",
			"parameters": [
				{ "name": "targetPath", "in": "body", "type": "string", "required": true }
			]
		}
	]
}
