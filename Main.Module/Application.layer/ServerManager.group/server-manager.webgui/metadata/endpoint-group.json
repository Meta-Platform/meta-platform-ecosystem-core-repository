{
    "params": [
        "serverManagerUrl",
        "serverName"
    ],
    "bound-params": [
        "serverService"
    ],
    "endpoints": [
        {
            "url": "/",
            "type": "web-graphic-user-interface",
            "params": {
                "entrypoint": "index.tsx",
