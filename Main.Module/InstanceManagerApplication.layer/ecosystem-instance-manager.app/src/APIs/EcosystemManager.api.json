{
	"name": "EcosystemManager",
	"endpoints": [
		{
			"summary": "ListPackages",
			"method": "GET",
			"path": "/list-packages"
		},
		{
			"summary": "PackageList",
			"method": "WS",
			"path": "/package-list"
		},
		{
			"summary": "ListInstances",
			"method": "GET",
			"path": "/list-instances"
		},
		{
			"summary": "InstanceList",
			"method": "WS",
			"path": "/instance-list"
		},
		{
			"summary": "LaunchProgressStream",
			"method": "WS",
			"path": "/launch-progress"
		},
		{
			"summary": "LaunchProgress",
			"method": "POST",
			"path": "/report-launch-progress",
			"parameters": [
				{
					"name": "launchId",
					"in": "body",
					"type": "string",
					"required": true
				},
				{
					"name": "phase",
					"in": "body",
					"type": "string",
					"required": true
				},
				{
					"name": "percentage",
					"in": "body",
					"type": "number",
					"required": false
				}
			]
		},
		{
			"summary": "RunPackage",
			"method": "POST",
			"path": "/run-package",
			"parameters": [
				{
					"name": "packagePath",
					"in": "body",
					"type": "string",
					"required": true
				},
				{
					"name": "startupParams",
					"in": "body",
					"type": "json",
					"required": false
				},
				{
					"name": "launchedBy",
					"in": "body",
					"type": "string",
					"required": false
				}
			]
		},
		{
			"summary": "StopPackage",
			"method": "POST",
			"path": "/stop-package",
			"parameters": [
				{
					"name": "packagePath",
					"in": "body",
					"type": "string",
					"required": true
				}
			]
		},
		{
			"summary": "StopInstance",
			"method": "POST",
			"path": "/stop-instance",
			"parameters": [
				{
					"name": "instanceId",
					"in": "body",
					"type": "string",
					"required": true
				}
			]
		}
	]
}