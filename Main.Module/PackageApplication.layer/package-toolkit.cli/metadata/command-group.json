{
    "bound-params": [
        "packageToolkitLib",
        "workspaceStoreLib"
    ],
    "commands": [
        {
            "namespace": "Workspace",
            "command": "workspace",
            "description": "Gerenciar workspaces (espaços de trabalho)",
            "children": [
                {
                    "namespace": "ListWorkspaces",
                    "path": "Commands/ListWorkspaces.command",
                    "command": "list",
                    "description": "Listar workspaces",
                    "parametersToLoad": [
                        "workspaceStoreLib"
                    ]
                },
                {
                    "namespace": "CreateWorkspace",
                    "path": "Commands/CreateWorkspace.command",
                    "command": "create [name] [path]",
                    "description": "Criar/atualizar uma workspace",
                    "parameters": [
                        {
                            "key": "name",
                            "paramType": "positional",
                            "valueType": "string",
                            "describe": "Nome da workspace"
                        },
                        {
                            "key": "path",
                            "paramType": "positional",
                            "valueType": "string",
                            "describe": "Caminho do diretório da workspace"
                        }
                    ],
                    "parametersToLoad": [
                        "workspaceStoreLib"
                    ]
                },
                {
                    "namespace": "RemoveWorkspace",
                    "path": "Commands/RemoveWorkspace.command",
                    "command": "remove [name]",
                    "description": "Remover uma workspace",
                    "parameters": [
                        {
                            "key": "name",
                            "paramType": "positional",
                            "valueType": "string",
                            "describe": "Nome da workspace"
                        }
                    ],
                    "parametersToLoad": [
                        "workspaceStoreLib"
                    ]
                }
            ]
        },
        {
            "namespace": "CreatePackage",
            "command": "create",
            "description": "Criar um pacote",
            "children": [
                {
                    "namespace": "CreateLibraryPackage",
                    "path": "Commands/CreateLibraryPackage.command",
                    "command": "library [packageName]",
                    "description": "Criar uma biblioteca",
                    "parameters": [
                        {
                            "key": "packageName",
                            "paramType": "positional",
                            "valueType": "string",
                            "describe": "Namespace do pacote"
                        }
                    ],
                    "parametersToLoad": [
                        "packageToolkitLib"
                    ]
                },
                {
                    "namespace": "CreateCommandlinePackage",
                    "path": "Commands/CreateCommandlinePackage.command",
                    "command": "commandline [packageName]",
                    "description": "Criar um pacote de linha de comando",
                    "parameters": [
                        {
                            "key": "packageName",
                            "paramType": "positional",
                            "valueType": "string",
                            "describe": "Namespace do pacote"
                        }
                    ],
                    "parametersToLoad": [
                        "packageToolkitLib"
                    ]
                },
                {
                    "namespace": "CreateServicesPackage",
                    "path": "Commands/CreateServicesPackage.command",
                    "command": "services [packageName]",
                    "description": "Criar um pacote de serviços",
                    "parameters": [
                        {
                            "key": "packageName",
                            "paramType": "positional",
                            "valueType": "string",
                            "describe": "Namespace do pacote"
                        }
                    ],
                    "parametersToLoad": [
                        "packageToolkitLib"
                    ]
                },
                {
                    "namespace": "CreatePackage",
                    "path": "Commands/CreatePackage.command",
                    "command": "package [packageName] [ext]",
                    "description": "Criar um pacote de qualquer tipo (lib, cli, service, webapp, webgui, webservice, app, desktopapp)",
                    "parameters": [
                        { "key": "packageName", "paramType": "positional", "valueType": "string", "describe": "Nome do pacote" },
                        { "key": "ext", "paramType": "positional", "valueType": "string", "describe": "Tipo/extensão do pacote" }
                    ],
                    "parametersToLoad": [ "packageToolkitLib" ]
                },
                {
                    "namespace": "CreateRepository",
                    "path": "Commands/CreateRepository.command",
                    "command": "repository [name]",
                    "description": "Criar um Repository (scaffold) no diretório atual",
                    "parameters": [
                        { "key": "name", "paramType": "positional", "valueType": "string", "describe": "Nome do repositório" }
                    ],
                    "parametersToLoad": [ "packageToolkitLib" ]
                },
                {
                    "namespace": "CreateContainer",
                    "path": "Commands/CreateContainer.command",
                    "command": "container [kind] [name]",
                    "description": "Criar um Module/Layer/Group no diretório atual",
                    "parameters": [
                        { "key": "kind", "paramType": "positional", "valueType": "string", "describe": "module | layer | group" },
                        { "key": "name", "paramType": "positional", "valueType": "string", "describe": "Nome do container" }
                    ],
                    "parametersToLoad": [ "packageToolkitLib" ]
                }
            ]
        }
    ]
}